{
  "default": {
    "identifier": "default",
    "description": "Default permissions for SwellLobster desktop",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "shell:allow-open",
      "fs:read-all",
      "fs:write-all",
      "dialog:allow-open",
      "dialog:allow-save",
      "process:allow-exit"
    ]
  }
}
