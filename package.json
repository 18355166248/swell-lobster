{
  "name": "swell-lobster",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "src/tide-lobster"
  ],
  "engines": {
    "node": ">=20.20.0"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --prefix apps/web-ui",
    "lint:fix": "npm run lint:fix --prefix apps/web-ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "dev:web": "concurrently -n backend,web -c blue,green \"npm run dev -w tide-lobster\" \"npm run dev -w swell-lobster\"",
    "dev:desktop": "concurrently -n backend,desktop -c blue,magenta \"npm run dev -w tide-lobster\" \"npm run dev -w swell-lobster-desktop\"",
    "build:desktop": "npm run build:pkg -w tide-lobster && npm run prepare:binaries -w swell-lobster-desktop && npm run build -w swell-lobster-desktop"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "apps/web-ui/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write",
      "node scripts/lint-staged-web-ui.mjs"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
