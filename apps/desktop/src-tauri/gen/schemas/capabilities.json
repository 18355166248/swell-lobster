{
  "default": {
    "identifier": "default",
    "description": "Default permissions for SwellLobster desktop",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "shell:allow-open",
      {
        "identifier": "shell:allow-execute",
        "allow": [{ "args": true, "name": "binaries/tide-lobster", "sidecar": true }]
      },
      "fs:read-all",
      "fs:write-all",
      "dialog:allow-open",
      "dialog:allow-save",
      "process:allow-exit"
    ]
  }
}
