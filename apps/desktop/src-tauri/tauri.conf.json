{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwellLobster",
  "version": "0.1.0",
  "identifier": "ai.swell.lobster",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../../web-ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SwellLobster",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/*": "binaries/"
    },
    "externalBin": ["binaries/tide-lobster"]
  }
}
